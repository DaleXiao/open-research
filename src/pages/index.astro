---
import Base from "../layouts/Base.astro";
---

<Base title="research · 论文精读工作台">
  <div class="app">
    <header class="topbar">
      <div class="brand">
        <span class="prompt">research</span><span class="cursor" aria-hidden="true">▋</span>
        <span class="tagline" data-i18n="brand.tagline">paper reader · 中英对照</span>
      </div>
      <div class="topbar-right">
        <div class="topbar-controls">
          <div id="uilang-switch" class="seg" role="group" aria-label="界面语言"></div>
          <button id="theme-btn" class="icon-btn theme-btn" type="button" aria-label="切换昼夜">
            <svg class="icon icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M20 14.5A8 8 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5z"/></svg>
            <svg class="icon icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2m0 16v2M2 12h2m16 0h2M4.9 4.9l1.4 1.4m11.4 11.4l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"/></svg>
          </button>
        </div>
        <div class="import">
          <span class="import-prefix" aria-hidden="true">&gt;</span>
          <input
            id="paper-input"
            type="text"
            placeholder="arxiv id or url, e.g. 1706.03762"
            data-i18n-attr="placeholder:import.placeholder;aria-label:import.trigger.aria"
            aria-label="Click to import a paper"
            role="button"
            readonly
            autocomplete="off"
            spellcheck="false"
          />
          <button id="import-btn" class="primary">
            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M12 3v12m0 0l-4-4m4 4l4-4M5 21h14"/></svg>
            <span data-i18n="import.btn">import</span>
          </button>
        </div>
        <button id="papers-open" class="icon-btn" type="button" aria-label="论文库" data-i18n-attr="aria-label:papers.open.aria">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M4 5a1 1 0 0 1 1-1h5v16H5a1 1 0 0 1-1-1V5z"/><path d="M14 4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-5V4z"/><path d="M7 8h0M7 11h0"/></svg>
          <span data-i18n="papers.open">papers</span>
        </button>
        <button id="qa-open" class="icon-btn" type="button" aria-label="AI 问 paper" data-i18n-attr="aria-label:qa.open.aria" aria-expanded="false" aria-controls="qa-drawer">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M21 12a8 8 0 0 1-8 8H7l-4 2 1-4a8 8 0 1 1 17-6z"/><path d="M9 11h6m-6 3h4"/></svg>
          <span data-i18n="qa.open">ask</span>
        </button>
        <button id="mindmap-open" class="icon-btn" type="button" aria-label="生成论文思维导图" data-i18n-attr="aria-label:mindmap.open.aria" aria-expanded="false" aria-controls="mindmap-overlay">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><circle cx="5" cy="12" r="2"/><circle cx="18" cy="6" r="2"/><circle cx="18" cy="18" r="2"/><path d="M7 12h4m0 0l5-5m-5 5l5 5"/></svg>
          <span data-i18n="mindmap.open">mindmap</span>
        </button>
        <button id="notes-open" class="icon-btn" type="button" aria-label="笔记面板" data-i18n-attr="aria-label:note.open.aria" aria-expanded="false" aria-controls="notes-drawer">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M6 3h12v18l-6-4-6 4V3z"/></svg>
          <span data-i18n="note.open">notes</span><span id="notes-count" class="notes-count" aria-hidden="true"></span>
        </button>
      </div>
    </header>

    <div class="status-line"><span class="status-prefix" aria-hidden="true">$</span> <span id="status" data-kind="info"></span></div>

    <div class="workbench">
      <aside class="sidebar">
        <div class="paper-meta"><h1 id="paper-title" data-i18n="paper.none">// no paper loaded</h1></div>
        <nav id="toc" class="toc" aria-label="目录" data-i18n-attr="aria-label:toc.aria"></nav>
      </aside>

      <main class="reader">
        <div class="reader-toolbar">
          <button id="translate-btn" disabled>
            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M4 5h7M7 4v1c0 4-1.5 7-4 9m1-4c0 2 2 4 5 4m6 6l3-7 3 7m-5-2h4"/></svg>
            <span data-i18n="translate.btn">translate --all</span>
          </button>
          <span id="progress" class="progress" data-done="0"></span>
          <div id="view-seg" class="seg" role="group" aria-label="显示语言" data-i18n-attr="aria-label:view.aria">
            <span class="seg-prefix" aria-hidden="true">lang:</span>
            <button data-mode="both" aria-pressed="true" data-i18n="view.both">both</button>
            <button data-mode="zh" aria-pressed="false" data-i18n="view.zh">zh</button>
            <button data-mode="en" aria-pressed="false" data-i18n="view.en">en</button>
          </div>
        </div>
        <article id="stream" class="stream" data-view="both">
          <p class="empty-hint">
            <span class="hint-prompt">research&nbsp;❯</span> <span data-i18n="empty.hint">import an arXiv paper to begin.
            公式与图表原样保留，译文按段懒翻——可整篇翻译，也可逐段点 [译]。</span>
          </p>
        </article>
      </main>
    </div>

    <!-- M5 「AI 问 paper」抽屉(右侧滑出,terminal 风) -->
    <aside id="qa-drawer" class="qa-drawer" data-open="0" aria-hidden="true" aria-label="AI 问 paper" data-i18n-attr="aria-label:qa.open.aria">
      <div class="qa-head">
        <span class="qa-title"><span class="qa-title-prompt">research</span>&nbsp;❯ <span data-i18n="qa.title">ask</span></span>
        <button id="qa-close" class="qa-close" type="button" aria-label="关闭" data-i18n-attr="aria-label:qa.close.aria">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"/></svg>
        </button>
      </div>
      <div id="qa-history" class="qa-history">
        <p class="qa-empty" data-i18n="qa.empty.import">// import a paper first</p>
      </div>
      <form id="qa-form" class="qa-form">
        <div id="qa-scope" class="seg qa-scope" role="group" aria-label="问答范围" data-i18n-attr="aria-label:qa.scope.aria">
          <span class="seg-prefix" aria-hidden="true">scope:</span>
          <button data-scope="full" type="button" aria-pressed="true" data-i18n="qa.scope.full">full</button>
          <button data-scope="selection" type="button" aria-pressed="false" data-i18n="qa.scope.selection">selection</button>
        </div>
        <p id="qa-sel-hint" class="qa-sel-hint" hidden></p>
        <div class="qa-input-row">
          <span class="qa-input-prefix" aria-hidden="true">&gt;</span>
          <input
            id="qa-q"
            type="text"
            placeholder="ask anything about this paper…"
            data-i18n-attr="placeholder:qa.input.placeholder"
            autocomplete="off"
            spellcheck="false"
          />
          <button id="qa-send" class="primary qa-send" type="submit" aria-label="发送" data-i18n-attr="aria-label:qa.send.aria"><span data-i18n="qa.send">send</span></button>
        </div>
      </form>
    </aside>

    <!-- F1 「批注/笔记」抽屉(右侧滑出,terminal 风,结构同 qa-drawer) -->
    <aside id="notes-drawer" class="qa-drawer notes-drawer" data-open="0" aria-hidden="true" aria-label="笔记面板" data-i18n-attr="aria-label:note.open.aria">
      <div class="qa-head">
        <span class="qa-title"><span class="qa-title-prompt">research</span>&nbsp;❯ <span data-i18n="note.title">notes</span></span>
        <button id="notes-close" class="qa-close" type="button" aria-label="关闭" data-i18n-attr="aria-label:note.close.aria">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"/></svg>
        </button>
      </div>
      <div id="notes-list" class="qa-history notes-list">
        <p class="note-empty" data-i18n="note.empty.none">// no notes yet</p>
      </div>
    </aside>

    <!-- F4 思维导图全屏遮罩(markmap SVG，terminal 皮) -->
    <div id="mindmap-overlay" class="mindmap-overlay" data-open="0" aria-hidden="true" role="dialog" aria-modal="true" aria-label="思维导图" data-i18n-attr="aria-label:mindmap.open.aria">
      <div class="mindmap-panel">
        <div class="mindmap-head">
          <span class="qa-title"><span class="qa-title-prompt">research</span>&nbsp;❯ <span data-i18n="mindmap.title">mindmap</span></span>
          <span id="mindmap-status" class="mindmap-status" data-kind="info"></span>
          <div class="mindmap-head-actions">
            <button id="mindmap-regen" class="mindmap-regen" type="button" aria-label="重新生成脑图" data-i18n-attr="aria-label:mindmap.regen.aria">
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/><path d="M3 21v-5h5"/></svg>
              <span data-i18n="mindmap.regen">regenerate</span>
            </button>
            <button id="mindmap-close" class="qa-close" type="button" aria-label="关闭" data-i18n-attr="aria-label:mindmap.close.aria">
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"/></svg>
            </button>
          </div>
        </div>
        <div id="mindmap-stage" class="mindmap-stage"></div>
      </div>
    </div>
  </div>
</Base>

<script>
  import { mountReader } from "../lib/reader";
  const root = document.querySelector<HTMLElement>(".app");
  if (root) mountReader(root);
</script>

<style>
  .app { display: flex; flex-direction: column; min-height: 100vh; }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    padding: var(--sp-2) var(--sp-6);
    border-bottom: 1px solid var(--c-line);
    background: var(--c-bg-raised);
    position: sticky;
    top: 0;
    z-index: 10;
    flex-wrap: wrap;
  }
  .brand { display: flex; align-items: baseline; gap: var(--sp-2); }
  .prompt {
    font-weight: 700;
    font-size: var(--fs-lg);
    color: var(--c-accent);
    letter-spacing: 0.02em;
    text-shadow: var(--c-glow);
  }
  .cursor {
    color: var(--c-accent);
    font-size: var(--fs-lg);
    animation: blink 1.1s steps(1) infinite;
    margin-left: -0.18em;
  }
  @keyframes blink { 50% { opacity: 0; } }
  @media (prefers-reduced-motion: reduce) { .cursor { animation: none; } }
  .tagline { color: var(--c-ink-faint); font-size: var(--fs-xs); }

  .topbar-right { display: flex; align-items: center; gap: var(--sp-3); flex: 1 1 40rem; justify-content: flex-start; }
  /* 语言 + 主题切换组，并排于 import 左侧（整组靠左） */
  .topbar-controls { display: inline-flex; align-items: center; gap: var(--sp-2); flex: 0 0 auto; }
  /* 顶栏控件统一高度基准 2.5rem（主题钮原偏低），box-sizing 保证 border+padding 不擑高 */
  .topbar-controls .seg,
  .topbar-controls .theme-btn,
  .topbar-right .icon-btn,
  #import-btn,
  .import input { height: 2.5rem; box-sizing: border-box; }
  .topbar-controls .seg,
  .topbar-controls .theme-btn,
  .topbar-right .icon-btn,
  #import-btn { display: inline-flex; align-items: center; }
  .theme-btn { padding: var(--sp-1) var(--sp-2); }
  /* 顶栏语言 seg 不用 .seg 的 margin-left:auto（那是 reader 工具栏 view-seg 用的） */
  .topbar-controls .seg { margin-left: 0; }
  /* import 输入框加长：flex-grow 吞空闲空间 → 把功能钮组推到右缘 */
  .import { display: flex; align-items: center; gap: var(--sp-2); flex: 1 1 auto; min-width: 16rem; }
  .import-prefix { color: var(--c-accent); font-weight: 700; }
  .import input {
    flex: 1;
    font: inherit;
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--c-ink);
    background: var(--c-bg-sunken);
    border: 1px solid var(--c-line);
    border-radius: var(--radius-sm);
    padding: var(--sp-2) var(--sp-3);
    caret-color: var(--c-accent);
  }
  .import input::placeholder { color: var(--c-ink-faint); }
  .import input:focus { border-color: var(--c-accent); outline: none; }

  .icon-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    white-space: nowrap;
    font-size: var(--fs-sm);
  }
  /* 昼夜：图标语义指示「点击后切到的目标」（）。
     夜间 → 显太阳（暗示可切白天）；白天 → 显月亮（暗示可切夜间）。 */
  .icon-moon { display: none; }
  .icon-sun { display: inline-block; }
  :root[data-theme="day"] .icon-sun { display: none; }
  :root[data-theme="day"] .icon-moon { display: inline-block; }
  @media (prefers-color-scheme: light) {
    :root:not([data-theme]) .icon-sun { display: none; }
    :root:not([data-theme]) .icon-moon { display: inline-block; }
  }

  #import-btn { display: inline-flex; align-items: center; gap: var(--sp-2); }

  .status-line {
    min-height: 1.5rem;
    padding: var(--sp-1) var(--sp-6);
    font-size: var(--fs-xs);
    border-bottom: 1px solid var(--c-line-soft);
    color: var(--c-ink-soft);
  }
  .status-prefix { color: var(--c-accent); font-weight: 700; }
  #status[data-kind="error"] { color: var(--c-danger); }
  #status[data-kind="ok"] { color: var(--c-ok); }
  #status[data-kind="info"] { color: var(--c-ink-soft); }

  .workbench { display: grid; grid-template-columns: 15rem 1fr; flex: 1; min-height: 0; }
  .sidebar {
    border-right: 1px solid var(--c-line);
    padding: var(--sp-6) var(--sp-4);
    overflow-y: auto;
    position: sticky;
    top: 3.2rem;
    align-self: start;
    max-height: calc(100vh - 3.2rem);
  }
  .paper-meta h1 {
    font-size: var(--fs-sm);
    font-weight: 500;
    line-height: 1.45;
    color: var(--c-ink-soft);
    margin-bottom: var(--sp-4);
    word-break: break-word;
  }

  /* ToC 列表/项是 reader.ts JS 运行期注入(无 astro scope cid),scoped 选择器永不命中 → :global */
  :global(.toc-list) { list-style: none; display: flex; flex-direction: column; gap: 1px; }
  :global(.toc-item a) {
    display: block;
    color: var(--c-ink-soft);
    font-size: var(--fs-xs);
    padding: var(--sp-1) var(--sp-2);
    border-left: 2px solid transparent;
  }
  :global(.toc-item a:hover) { color: var(--c-accent); background: var(--c-bg-sunken); border-left-color: var(--c-accent); text-decoration: none; }
  :global(.toc-l1 a) { padding-left: var(--sp-4); color: var(--c-ink-faint); }
  :global(.toc-l2 a) { padding-left: var(--sp-6); }

  .reader { overflow-y: auto; }
  .reader-toolbar {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    padding: var(--sp-2) var(--sp-8);
    border-bottom: 1px solid var(--c-line-soft);
    position: sticky;
    top: 0;
    background: var(--c-bg);
    z-index: 5;
    flex-wrap: wrap;
  }
  #translate-btn { display: inline-flex; align-items: center; gap: var(--sp-2); }
  .progress { font-size: var(--fs-xs); color: var(--c-ink-soft); }
  .progress[data-done="1"] { color: var(--c-ok); }

  /* 中英显示切换:方括号命令行式分段 [ both | zh | en ] */
  .seg {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
    border: 1px solid var(--c-line);
    border-radius: var(--radius-sm);
    padding: 1px var(--sp-2);
    font-size: var(--fs-xs);
  }
  .seg-prefix { color: var(--c-ink-faint); padding: 0 var(--sp-1); }
  .seg button {
    border: 0;
    border-radius: 0;
    background: transparent;
    color: var(--c-ink-soft);
    padding: 1px var(--sp-2);
    font-size: var(--fs-xs);
  }
  .seg button:hover:not([aria-pressed="true"]) { color: var(--c-accent); background: transparent; }
  .seg button[aria-pressed="true"] { color: var(--c-accent); text-shadow: var(--c-glow); }
  .seg button[aria-pressed="true"]::before { content: "["; }
  .seg button[aria-pressed="true"]::after { content: "]"; }

  .stream { max-width: 80rem; margin: 0 auto; padding: var(--sp-8); }
  .empty-hint { color: var(--c-ink-faint); font-size: var(--fs-sm); padding: var(--sp-8) 0; max-width: var(--measure); line-height: 1.8; }
  .hint-prompt { color: var(--c-accent); }

  /* ── F2 最近导入列表（空工作区）。reader.ts JS 运行期创建，无 astro cid → :global ── */
  :global(.recent) { max-width: var(--measure); padding: var(--sp-6) 0; }
  :global(.recent-head) {
    color: var(--c-accent);
    font-size: var(--fs-sm);
    margin-bottom: var(--sp-3);
    text-shadow: var(--c-glow);
  }
  :global(.recent-head::before) { content: "research ❯ "; color: var(--c-ink-faint); text-shadow: none; }
  :global(.recent-empty) { color: var(--c-ink-faint); font-size: var(--fs-sm); padding: var(--sp-4) 0; }
  :global(.recent-list) { list-style: none; display: flex; flex-direction: column; gap: 1px; }
  :global(.recent-item) { display: flex; align-items: stretch; }
  :global(.recent-row) {
    display: flex;
    align-items: baseline;
    gap: var(--sp-3);
    flex: 1 1 auto;
    min-width: 0;
    text-align: left;
    border: 0;
    border-left: 2px solid transparent;
    border-radius: 0;
    background: transparent;
    color: var(--c-ink-soft);
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    padding: var(--sp-2) var(--sp-3);
  }
  :global(.recent-row:hover) {
    color: var(--c-accent);
    background: var(--c-bg-sunken);
    border-left-color: var(--c-accent);
  }
  :global(.recent-arrow) { color: var(--c-accent); font-weight: 700; flex: 0 0 auto; }
  :global(.recent-name) {
    flex: 1 1 auto;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  :global(.recent-tag) {
    flex: 0 0 auto;
    color: var(--c-ink-faint);
    font-size: var(--fs-xs);
  }
  :global(.recent-tag::before) { content: "["; }
  :global(.recent-tag::after) { content: "]"; }
  :global(.recent-date) { flex: 0 0 auto; color: var(--c-ink-faint); font-size: var(--fs-xs); }

  /* F5 删除钮（每项右侧垃圾桶）+ 确认对话框。JS 运行期 → :global */
  :global(.recent-del) {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 var(--sp-2);
    border: 0;
    border-radius: 0;
    background: transparent;
    color: var(--c-ink-faint);
    opacity: 0;
    transition: opacity var(--transition), color var(--transition);
  }
  :global(.recent-del .icon) { width: 0.95rem; height: 0.95rem; }
  :global(.recent-item:hover .recent-del),
  :global(.recent-del:focus-visible) { opacity: 1; }
  :global(.recent-del:hover) { color: var(--c-danger); background: transparent; }

  :global(.confirm-overlay) {
    position: fixed;
    inset: 0;
    z-index: 70;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--sp-6);
    background: color-mix(in srgb, var(--c-bg-sunken) 78%, transparent);
    backdrop-filter: blur(2px);
  }
  :global(.confirm-card) {
    width: min(28rem, 92vw);
    background: var(--c-bg-raised);
    border: 1px solid var(--c-line);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow);
    padding: var(--sp-6);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  :global(.confirm-msg) { color: var(--c-ink); font-size: var(--fs-sm); line-height: 1.6; word-break: break-word; }
  :global(.confirm-warn) { color: var(--c-pending); font-size: var(--fs-xs); }
  :global(.confirm-err) { color: var(--c-danger); font-size: var(--fs-xs); }
  :global(.confirm-row) { display: flex; justify-content: flex-end; gap: var(--sp-2); margin-top: var(--sp-1); }
  :global(.confirm-ok) { background: var(--c-danger); border-color: var(--c-danger); color: var(--c-bg); }
  :global(.confirm-ok:hover:not(:disabled)) { opacity: 0.88; background: var(--c-danger); border-color: var(--c-danger); color: var(--c-bg); }
  :global(.confirm-ok:disabled) { opacity: 0.5; }

  /* F8：import 弹框 — 复用 confirm-overlay/card 骨架，输入卡沿用 qa-input-row terminal 风。 */
  :global(.import-card) { gap: var(--sp-2); }
  :global(.import-dialog-title) {
    color: var(--c-accent);
    font-size: var(--fs-sm);
